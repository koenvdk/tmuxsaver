#!/usr/bin/env bash
# tmuxsaver - minimal tmux session saver
# Saves working directory and bash/zsh history per session.
# No windows, panes, or running programs are preserved.
#
# Usage: tmuxsaver <command> [options]
#   save          Save all current tmux sessions
#   restore       Restore previously saved sessions
#   list          List saved sessions
#   clean         Remove all saved session data
#   setup-shell   Print the shell integration snippet
#   setup-tmux    Add save-on-detach hook to ~/.tmux.conf
#
# Options:
#   --dir <path>  Override save directory (default: ~/.tmuxsaver)
#   --quiet       Suppress informational output

set -uo pipefail

TMUXSAVER_VERSION="0.4.5"
SAVE_DIR="${TMUXSAVER_DIR:-$HOME/.tmuxsaver}/sessions"
QUIET=0

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log()  { [[ $QUIET -eq 0 ]] && echo "$*" >&2 || true; }
info() { log "[tmuxsaver] $*"; }
warn() { echo "[tmuxsaver] WARNING: $*" >&2; }
die()  { echo "[tmuxsaver] ERROR: $*" >&2; exit 1; }

require_tmux() {
    command -v tmux &>/dev/null || die "tmux is not installed or not in PATH"
    # Use list-sessions (== `tmux ls`) as the probe: `tmux info` can fail in
    # contexts without a TTY/target even when a server is running.
    tmux list-sessions &>/dev/null || die "no tmux server is running"
}

# ---------------------------------------------------------------------------
# Save
# ---------------------------------------------------------------------------

cmd_save() {
    require_tmux

    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null) || {
        info "No active tmux sessions to save."
        return 0
    }

    mkdir -p "$SAVE_DIR"
    local count=0

    while IFS= read -r session; do
        [[ -z "$session" ]] && continue

        local session_dir="$SAVE_DIR/$session"
        mkdir -p "$session_dir"

        # Working directory: use the most recently active pane
        local workdir
        workdir=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null) || continue
        echo "$workdir" > "$session_dir/workdir"

        local histfile="$session_dir/history"
        if [[ -f "$histfile" ]]; then
            info "Saved session '$session': $workdir (history present)"
        else
            info "Saved session '$session': $workdir (no per-session history — run 'tmuxsaver setup-shell' to enable)"
        fi

        count=$(( count + 1 ))
    done <<< "$sessions"

    info "Saved $count session(s) to $SAVE_DIR"
}

# ---------------------------------------------------------------------------
# Restore
# ---------------------------------------------------------------------------

cmd_restore() {
    command -v tmux &>/dev/null || { warn "tmux is not installed"; return 0; }
    tmux list-sessions &>/dev/null || tmux start-server

    [[ -d "$SAVE_DIR" ]] || {
        info "No saved sessions found at $SAVE_DIR"
        return 0
    }

    local count=0

    for session_dir in "$SAVE_DIR"/*/; do
        [[ -d "$session_dir" ]] || continue

        local session
        session=$(basename "$session_dir")
        local workdir_file="$session_dir/workdir"
        local histfile="$session_dir/history"

        [[ -f "$workdir_file" ]] || { warn "Skipping '$session': no workdir file"; continue; }
        local workdir
        workdir=$(cat "$workdir_file")

        if tmux has-session -t "$session" 2>/dev/null; then
            info "Session '$session' already exists — skipping"
            continue
        fi

        if [[ ! -d "$workdir" ]]; then
            warn "Saved workdir '$workdir' for session '$session' no longer exists; using \$HOME"
            workdir="$HOME"
        fi

        tmux new-session -d -s "$session" -c "$workdir"

        # Point the new shell at the saved history file.
        # Leading space avoids adding this command to history itself
        # (requires HISTCONTROL=ignorespace or ignoreboth).
        if [[ -f "$histfile" ]]; then
            tmux send-keys -t "$session" \
                " export HISTFILE='$histfile'; history -c; history -r; history -s ''" \
                Enter
        fi

        info "Restored session '$session' at $workdir"
        count=$(( count + 1 ))
    done

    info "Restored $count session(s)"
}

# ---------------------------------------------------------------------------
# List
# ---------------------------------------------------------------------------

cmd_list() {
    [[ -d "$SAVE_DIR" ]] || { echo "No saved sessions."; return 0; }

    local found=0
    for session_dir in "$SAVE_DIR"/*/; do
        [[ -d "$session_dir" ]] || continue
        local session
        session=$(basename "$session_dir")
        local workdir="(unknown)"
        [[ -f "$session_dir/workdir" ]] && workdir=$(cat "$session_dir/workdir")
        local has_history="no"
        [[ -f "$session_dir/history" ]] && has_history="yes"
        printf "  %-20s  %s  (history: %s)\n" "$session" "$workdir" "$has_history"
        found=$(( found + 1 ))
    done

    [[ $found -eq 0 ]] && echo "No saved sessions."
}

# ---------------------------------------------------------------------------
# Clean
# ---------------------------------------------------------------------------

cmd_clean() {
    [[ -d "$SAVE_DIR" ]] || { info "Nothing to clean."; return 0; }

    if [[ $QUIET -eq 0 ]]; then
        read -r -p "[tmuxsaver] Remove all saved session data at $SAVE_DIR? [y/N] " answer
        [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return 0; }
    fi

    rm -rf "$SAVE_DIR"
    info "Cleaned $SAVE_DIR"
}

# ---------------------------------------------------------------------------
# Setup-shell
# ---------------------------------------------------------------------------

cmd_setup_shell() {
    cat /usr/share/tmuxsaver/tmuxsaver.sh 2>/dev/null || \
        cat "$(dirname "$(realpath "$0")")/shell/tmuxsaver.sh"
}

# ---------------------------------------------------------------------------
# Setup-tmux
# ---------------------------------------------------------------------------

cmd_setup_tmux() {
    local tmux_conf="$HOME/.tmux.conf"
    local marker="# tmuxsaver: save on detach"

    if grep -qF "$marker" "$tmux_conf" 2>/dev/null; then
        info "tmux hook already present in $tmux_conf"
        return 0
    fi

    printf '\n%s\nset-hook -ga client-detached "run-shell \\"tmuxsaver save --quiet || true\\""\n' \
        "$marker" >> "$tmux_conf"
    info "Added save-on-detach hook to $tmux_conf"
    info "Reload now with: tmux source-file $tmux_conf"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

COMMAND=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        save|restore|list|clean|setup-shell|setup-tmux)
            COMMAND="$1"
            shift
            ;;
        --dir)
            [[ -n "${2:-}" ]] || die "--dir requires a path argument"
            SAVE_DIR="$2/sessions"
            shift 2
            ;;
        --quiet|-q)
            QUIET=1
            shift
            ;;
        --version|-v)
            echo "tmuxsaver $TMUXSAVER_VERSION"
            exit 0
            ;;
        --help|-h)
            sed -n '2,12p' "$0"
            exit 0
            ;;
        *)
            die "Unknown argument: $1 (try --help)"
            ;;
    esac
done

[[ -n "$COMMAND" ]] || { sed -n '2,12p' "$0"; exit 1; }

case "$COMMAND" in
    save)         cmd_save ;;
    restore)      cmd_restore ;;
    list)         cmd_list ;;
    clean)        cmd_clean ;;
    setup-shell)  cmd_setup_shell ;;
    setup-tmux)   cmd_setup_tmux ;;
esac
