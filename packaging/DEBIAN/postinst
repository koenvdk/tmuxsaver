#!/bin/bash
set -e

SNIPPET=/usr/share/tmuxsaver/tmuxsaver.sh
MARKER="# tmuxsaver shell integration"

# ── Systemd: enable save-on-logout for all users ─────────────────────────────
if command -v systemctl &>/dev/null; then
    systemctl --global enable tmuxsaver-save.service 2>/dev/null && \
        echo "tmuxsaver: enabled tmuxsaver-save.service globally (save on logout)"
fi

# ── Per-user setup ────────────────────────────────────────────────────────────
# SUDO_USER is set when the user ran `sudo apt install`.
if [[ -n "${SUDO_USER:-}" ]] && [[ "$SUDO_USER" != "root" ]]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)

    # Shell hook: append to rc files
    for rcfile in "$USER_HOME/.bashrc" "$USER_HOME/.zshrc"; do
        [[ -f "$rcfile" ]] || continue
        if grep -qF "$MARKER" "$rcfile"; then
            echo "tmuxsaver: shell hook already present in $rcfile — skipping"
        else
            { echo ""; cat "$SNIPPET"; } >> "$rcfile"
            echo "tmuxsaver: shell hook appended to $rcfile"
        fi
    done

    # tmux hook: add save-on-detach to ~/.tmux.conf
    sudo -u "$SUDO_USER" tmuxsaver setup-tmux 2>/dev/null || true
fi

echo ""
echo "tmuxsaver installed."
echo "  - Sessions are saved automatically when you detach from tmux."
echo "  - On next login, your terminal will auto-attach to restored sessions."
echo ""
echo "To also save on logout (belt-and-suspenders):"
echo "  systemctl --user enable --now tmuxsaver-save.service"
echo ""
echo "To restore sessions on login automatically:"
echo "  systemctl --user enable --now tmuxsaver-restore.service"
echo ""
