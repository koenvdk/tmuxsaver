#!/bin/bash
set -e

SNIPPET=/usr/share/tmuxsaver/tmuxsaver.sh
BEGIN_MARKER="# tmuxsaver:begin"
END_MARKER="# tmuxsaver:end"

# ── Systemd: enable save-on-logout for all users ─────────────────────────────
if command -v systemctl &>/dev/null; then
    systemctl --global enable tmuxsaver-save.service 2>/dev/null && \
        echo "tmuxsaver: enabled tmuxsaver-save.service globally (save on logout)"
fi

# ── Per-user setup ────────────────────────────────────────────────────────────
if [[ -n "${SUDO_USER:-}" ]] && [[ "$SUDO_USER" != "root" ]]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)

    for rcfile in "$USER_HOME/.bashrc" "$USER_HOME/.zshrc"; do
        [[ -f "$rcfile" ]] || continue

        # Remove any existing tmuxsaver block (old or new style) then re-append.
        # Old style had no end marker; new style has tmuxsaver:begin/end.
        # Python handles the multi-line removal cleanly.
        python3 - "$rcfile" "$SNIPPET" <<'PYEOF'
import re, sys, pathlib

rcfile  = pathlib.Path(sys.argv[1])
snippet = pathlib.Path(sys.argv[2]).read_text()
content = rcfile.read_text()

# Remove block between new-style markers (inclusive)
content = re.sub(
    r'\n# tmuxsaver:begin.*?# tmuxsaver:end\n',
    '\n',
    content,
    flags=re.DOTALL,
)
# Remove old-style block (no end marker): from first tmuxsaver comment to closing fi
content = re.sub(
    r'\n# tmuxsaver shell integration.*?^fi\n',
    '\n',
    content,
    flags=re.DOTALL | re.MULTILINE,
)

rcfile.write_text(content.rstrip('\n') + '\n\n' + snippet)
PYEOF
        echo "tmuxsaver: shell hook updated in $rcfile"
    done

    # tmux save-on-detach hook
    sudo -u "$SUDO_USER" tmuxsaver setup-tmux 2>/dev/null || true
fi

echo ""
echo "tmuxsaver installed."
echo "  - Sessions are saved automatically when you detach from tmux."
echo ""
echo "Reload your shell now:  source ~/.bashrc"
echo ""
echo "Optional — auto-attach to restored sessions on login:"
echo "  Add TMUXSAVER_AUTO_ATTACH=1 to your ~/.bashrc or ~/.profile"
echo ""
echo "Optional — restore sessions on login via systemd:"
echo "  systemctl --user enable --now tmuxsaver-restore.service"
echo ""
